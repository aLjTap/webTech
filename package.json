{
  "name": "webtech-tests",
  "version": "1.0.0",
  "description": "Validation scripts for HTML/CSS",
  "scripts": {
    "test:html": "htmlhint \"**/*.html\"",
    "test:css": "stylelint \"**/*.css\"",
    "check": "npm run test:html && npm run test:css"
  },
  "devDependencies": {
    "htmlhint": "^1.1.4",
    "stylelint": "^16.5.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
