{
  "$schema": "https://raw.githubusercontent.com/markuplint/markuplint/main/packages/markuplint/src/schema.json",
  "rules": {
    "html-has-lang": true,
    "html-has-doctype": true,
    "doctype-html5": true,
    "attr-spacing": true,
    "indent": 2,
    "line-end-style": "lf",
    "no-duplicate-attr": true,
    "no-empty-title": true,
    "no-target-blank": true
  }
}
